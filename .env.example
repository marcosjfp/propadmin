# ===========================================
# Variáveis de Ambiente - Administrador de Propriedades
# ===========================================
# Copie este arquivo para .env e preencha os valores

# Banco de Dados MySQL
# Formato: mysql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=mysql://root:rootpass123@localhost:3307/administrador_de_propriedades

# Ambiente (development ou production)
NODE_ENV=development

# Porta do servidor
PORT=3000

# Chave secreta para JWT - OBRIGATÓRIO
# Gere com: openssl rand -hex 32
# ATENÇÃO: Nunca use o valor padrão em produção!
JWT_SECRET=troque-este-valor-por-uma-chave-segura-de-64-caracteres-gerada-com-openssl

# ===========================================
# Variáveis para Deploy em Produção
# ===========================================
# DB_PASSWORD=senha_segura_do_usuario
# DB_ROOT_PASSWORD=senha_segura_do_root

# URL base da aplicação (para CORS)
# CLIENT_URL=https://seu-dominio.com

