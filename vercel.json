{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/trpc/(.*)", "destination": "/api/trpc/$1" },
    { "source": "/((?!api|trpc|assets|favicon.ico).*)", "destination": "/index.html" }
  ]
}
